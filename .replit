modules = ["nodejs-24", "python-3.12"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Radio Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Icecast Server"

[[workflows.workflow]]
name = "Radio Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 8099/tcp 2>/dev/null; sleep 1; cd radio-backend && python3 -m uvicorn main:app --host 0.0.0.0 --port 8099 --workers 1 --log-level info"

[[workflows.workflow]]
name = "Icecast Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mkdir -p /home/runner/workspace/icecast-data/log /home/runner/workspace/icecast-data/web /home/runner/workspace/icecast-data/admin && ICECAST_BASE=$(dirname $(which icecast))/../share/icecast && cp -r \"$ICECAST_BASE/web\"/* /home/runner/workspace/icecast-data/web/ 2>/dev/null; cp -r \"$ICECAST_BASE/admin\"/* /home/runner/workspace/icecast-data/admin/ 2>/dev/null; fuser -k 8000/tcp 2>/dev/null; sleep 1; icecast -c /home/runner/workspace/radio-backend/icecast-replit.xml"
waitForPort = 8000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]
