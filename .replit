modules = ["python-3.12"]
[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[agent]
expertMode = true

[userenv]

[userenv.shared]
API_HOST = "0.0.0.0"
API_PORT = "5000"
AUDIO_BITRATE = "128"
AUDIO_CHANNELS = "2"
AUDIO_SAMPLERATE = "44100"
AUTODJ_ENABLED = "true"
AUTODJ_PLAYLISTS = "https://www.youtube.com/playlist?list=PLDIoUOhQQPlXzhp-83rECoLaV6BwFtNC4"
AUTODJ_REFRESH_INTERVAL = "3600"
AUTODJ_SHUFFLE = "true"
FFMPEG_PATH = "ffmpeg"
FFMPEG_RECONNECT_DELAY = "5"
ICECAST_DESCRIPTION = "Live internet radio stream"
ICECAST_GENRE = "Mixed"
ICECAST_HOST = "localhost"
ICECAST_MOUNT = "/stream"
ICECAST_NAME = "Itachi Hits Radio"
ICECAST_PORT = "8000"
ICECAST_PUBLIC = "false"
ICECAST_USER = "source"
LOG_BACKUP_COUNT = "5"
LOG_DIR = "/home/runner/workspace/icecast-data/log"
LOG_LEVEL = "INFO"
LOG_MAX_BYTES = "10485760"
WATCHDOG_INTERVAL = "10"
WATCHDOG_MAX_SILENCE = "30"
YTDLP_FORMAT = "best"
YTDLP_MAX_DURATION = "7200"
YTDLP_TIMEOUT = "30"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start-replit.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
