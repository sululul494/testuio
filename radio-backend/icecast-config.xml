<icecast>
    <location>Earth</location>
    <admin>admin@example.com</admin>
    <limits>
        <clients>100</clients>
        <sources>5</sources>
        <queue-size>524288</queue-size>
        <client-timeout>30</client-timeout>
        <header-timeout>15</header-timeout>
        <source-timeout>10</source-timeout>
        <burst-on-connect>1</burst-on-connect>
        <burst-size>65535</burst-size>
    </limits>
    <authentication>
        <source-password>joy@2007</source-password>
        <relay-password>joy@2007</relay-password>
        <admin-user>itachi</admin-user>
        <admin-password>joy@2007</admin-password>
    </authentication>
    <hostname>localhost</hostname>
    <listen-socket>
        <port>8000</port>
    </listen-socket>
    <http-headers>
        <header name="Access-Control-Allow-Origin" value="*"/>
    </http-headers>
    <paths>
        <basedir>/nix/store/czx4m1fqj4vsjcp24k2ca8lm5dcphvyp-icecast-2.4.4/share/icecast</basedir>
        <logdir>/tmp/icecast-logs</logdir>
        <webroot>/nix/store/czx4m1fqj4vsjcp24k2ca8lm5dcphvyp-icecast-2.4.4/share/icecast/web</webroot>
        <adminroot>/nix/store/czx4m1fqj4vsjcp24k2ca8lm5dcphvyp-icecast-2.4.4/share/icecast/admin</adminroot>
        <pidfile>/tmp/icecast.pid</pidfile>
    </paths>
    <logging>
        <accesslog>access.log</accesslog>
        <errorlog>error.log</errorlog>
        <loglevel>3</loglevel>
        <logsize>10000</logsize>
    </logging>
    <security>
        <chroot>0</chroot>
    </security>
</icecast>
