# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Optional: set a secret token to protect API endpoints (not yet enforced)
# API_SECRET=your-secret-token
LOG_LEVEL=INFO

# ── Icecast ───────────────────────────────────────────────────────────────────
ICECAST_HOST=localhost
ICECAST_PORT=8000
ICECAST_USER=source
ICECAST_PASSWORD=hackme
ICECAST_MOUNT=/stream
ICECAST_NAME=My Internet Radio
ICECAST_DESCRIPTION=An awesome internet radio station
ICECAST_GENRE=Mixed
ICECAST_PUBLIC=false

# ── AutoDJ ────────────────────────────────────────────────────────────────────
# Comma-separated list of YouTube playlist URLs
AUTODJ_PLAYLISTS=https://www.youtube.com/playlist?list=PLxxxxxxxxxxxxxxx
AUTODJ_SHUFFLE=true
# How often (seconds) to refresh playlists from YouTube
AUTODJ_REFRESH_INTERVAL=3600
AUTODJ_ENABLED=true

# ── Audio ─────────────────────────────────────────────────────────────────────
AUDIO_BITRATE=128
AUDIO_SAMPLERATE=44100
AUDIO_CHANNELS=2

# ── yt-dlp ───────────────────────────────────────────────────────────────────
YTDLP_FORMAT=bestaudio/best
# Skip tracks longer than this many seconds (default: 2 hours)
YTDLP_MAX_DURATION=7200
YTDLP_TIMEOUT=30

# ── FFmpeg ────────────────────────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
FFMPEG_RECONNECT_DELAY=5

# ── Watchdog ──────────────────────────────────────────────────────────────────
WATCHDOG_INTERVAL=10
WATCHDOG_MAX_SILENCE=30

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_DIR=/app/logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
