<?xml version="1.0"?>
<icecast>
    <location>Earth</location>
    <admin>admin@example.com</admin>
    <limits>
        <clients>100</clients>
        <sources>5</sources>
        <queue-size>524288</queue-size>
        <client-timeout>30</client-timeout>
        <header-timeout>15</header-timeout>
        <source-timeout>10</source-timeout>
        <burst-on-connect>1</burst-on-connect>
        <burst-size>262144</burst-size>
    </limits>
    <authentication>
        <source-password>__ICECAST_PASSWORD__</source-password>
        <relay-password>__ICECAST_PASSWORD__</relay-password>
        <admin-user>itachi</admin-user>
        <admin-password>__ICECAST_ADMIN_PASSWORD__</admin-password>
    </authentication>
    <hostname>localhost</hostname>
    <listen-socket>
        <port>8000</port>
    </listen-socket>
    <http-headers>
        <header name="Access-Control-Allow-Origin" value="*"/>
    </http-headers>
    <mount>
        <mount-name>/stream</mount-name>
        <password>__ICECAST_PASSWORD__</password>
        <max-listeners>1000</max-listeners>
        <burst-on-connect>1</burst-on-connect>
        <burst-size>524288</burst-size>
        <queue-size>1048576</queue-size>
        <client-timeout>60</client-timeout>
        <source-timeout>60</source-timeout>
        <stream-name>Itachi Hits Radio</stream-name>
        <stream-description>Live internet radio stream</stream-description>
        <genre>Mixed</genre>
        <public>0</public>
    </mount>
    <paths>
        <basedir>/home/runner/workspace/icecast-data</basedir>
        <logdir>/home/runner/workspace/icecast-data/log</logdir>
        <webroot>/home/runner/workspace/icecast-data/web</webroot>
        <adminroot>/home/runner/workspace/icecast-data/admin</adminroot>
        <pidfile>/home/runner/workspace/icecast-data/icecast.pid</pidfile>
        <alias source="/" destination="/status.xsl"/>
    </paths>
    <logging>
        <accesslog>access.log</accesslog>
        <errorlog>error.log</errorlog>
        <loglevel>3</loglevel>
        <logsize>10000</logsize>
    </logging>
    <security>
        <chroot>0</chroot>
    </security>
</icecast>
